generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  garcom
  cozinha
  caixa
  gerente
}

enum ItemStatus {
  pendente
  em_preparo
  pronto
  entregue
}

enum PaymentType {
  dinheiro
  credito
  debito
  pix
}

model Employee {
  id        String      @id @default(cuid())
  name      String
  username  String      @unique
  password  String
  role      Role
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  comandas  Comanda[]   @relation("ComandaWaiter")
  items     OrderItem[] @relation("ItemWaiter")

  @@map("employees")
}

model Product {
  id            String      @id @default(cuid())
  name          String
  price         Decimal     @db.Decimal(10, 2)
  category      String      @default("Outros")
  available     Boolean     @default(true)
  goesToKitchen Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]

  @@map("products")
}

model Comanda {
  id         String      @id @default(cuid())
  table      String      @map("table_label")
  customer   String?
  waiterName String
  waiterId   String?
  waiter     Employee?   @relation("ComandaWaiter", fields: [waiterId], references: [id], onDelete: SetNull)
  items      OrderItem[]
  payments   Payment[]
  open       Boolean     @default(true)
  createdAt  DateTime    @default(now())
  closedAt   DateTime?

  @@map("comandas")
}

model OrderItem {
  id            String     @id @default(cuid())
  comandaId     String
  comanda       Comanda    @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  productId     String
  product       Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  name          String
  price         Decimal    @db.Decimal(10, 2)
  qty           Int
  status        ItemStatus @default(pendente)
  sentToKitchen Boolean    @default(false)
  waiterName    String
  waiterId      String?
  waiter        Employee?  @relation("ItemWaiter", fields: [waiterId], references: [id], onDelete: SetNull)
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([comandaId])
  @@index([productId])
  @@index([waiterId])
  @@map("order_items")
}

model Payment {
  id        String      @id @default(cuid())
  comandaId String
  comanda   Comanda     @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  type      PaymentType
  amount    Decimal     @db.Decimal(10, 2)
  createdAt DateTime    @default(now())

  @@index([comandaId])
  @@map("payments")
}
